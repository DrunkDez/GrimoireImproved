// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  name          String?
  passwordHash  String
  isAdmin       Boolean     @default(false)
  resetToken    String?     @unique
  resetTokenExpiry DateTime?
  characters    Character[]
  rotes         Rote[]      // User's created rotes
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  wonders       Wonder[] 
}

model GuideContent {
  id           String   @id @default(cuid())
  stepId       String   @unique
  guidanceText String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Character {
  id           String          @id @default(cuid())
  name         String
  faction      String          // Tradition/affiliation from guided creation
  concept      String?         // Character concept/background
  wonders      CharacterWonder[] 
  
  // Basic Info from guided creation
  player       String?         // Player's name
  chronicle    String?         // Campaign name
  nature       String?         // Nature archetype
  demeanor     String?         // Demeanor archetype
  essence      String?         // Dynamic, Pattern, Primordial, Questing
  sect         String?         // Sect (optional)
  
  // Stats (stored as JSON for flexibility)
  attributes   Json?           // { strength: 2, dexterity: 3, ... }
  abilities    Json?           // { alertness: 2, brawl: 1, ... }
  spheres      Json?           // { correspondence: 2, forces: 1, ... }
  backgrounds  Json?           // { avatar: 3, library: 2, ... }
  specialties  Json?           // { brawl: "Dirty Fighting", ... }
  
  // Derived from guided creation
  arete        Int?            // Total arete (base 1 + freebie dots)
  willpower    Int?            // Total willpower (base 5 + freebie dots)
  
  // Freebie tracking (for editing later)
  freebieDots  Json?           // Store all freebie allocations
  merits       Json?           // Array of { id, name, cost }
  flaws        Json?           // Array of { id, name, cost }
  
  // Metadata
  avatar       String?         // Avatar description
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  rotes        CharacterRote[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // === NEW: Experience Tracking ===
  totalExperience     Int      @default(0)  // Total XP earned
  spentExperience     Int      @default(0)  // XP spent on improvements
  
  // === NEW: Relations for post-creation additions ===
  experienceLog       ExperienceLog[]
  characterMerits     CharacterMerit[]
  characterFlaws      CharacterFlaw[]
  characterBackgrounds CharacterBackground[]

  // Custom XP costs (optional per character)
  useCustomXpCosts    Boolean  @default(false)
  customXpCosts       Json?    // Custom cost overrides

  @@index([userId])
  @@index([faction])
}

model ExperienceLog {
  id            String    @id @default(cuid())
  characterId   String
  character     Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  
  // Transaction details
  type          String    // "gain" or "spend"
  amount        Int       // Positive for gains, negative for spending
  
  // What was it for?
  category      String?   // "Attribute", "Ability", "Arete", "Willpower", "Merit", "Background", etc.
  itemName      String?   // Specific item bought (e.g., "Strength", "Occult", "Resources")
  fromRating    Int?      // Old rating (for improvements)
  toRating      Int?      // New rating (for improvements)
  
  description   String    @db.Text  // Free text description
  
  // Cost tracking
  officialCost  Int?      // What the official rules say
  actualCost    Int?      // What was actually paid (could be custom)
  usedCustom    Boolean   @default(false)  // Did player use custom cost?
  
  // Metadata
  sessionDate   DateTime? // Game session date
  createdAt     DateTime  @default(now())
  createdBy     String?   // User who added it
  
  @@index([characterId])
  @@index([type])
  @@index([createdAt])
}

model CharacterRote {
  id          String    @id @default(cuid())
  characterId String
  roteId      String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  rote        Rote      @relation(fields: [roteId], references: [id], onDelete: Cascade)
  notes       String?   @db.Text // Personal notes about how they use this rote
  specialty   Boolean   @default(false) // Is this a specialty rote?
  createdAt   DateTime  @default(now())
  
  @@unique([characterId, roteId]) // Can't assign same rote twice to one character
  @@index([characterId])
  @@index([roteId])
}

model Rote {
  id          String          @id @default(cuid())
  name        String
  tradition   String
  description String          @db.Text
  spheres     Json            // Store as JSON: { "Forces": 3, "Prime": 2 }
  level       String
  pageRef     String?
  userId      String?         // Optional - null for admin-created rotes
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  characters  CharacterRote[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([tradition])
  @@index([level])
  @@index([userId])
}

// ============================================
// POST-CREATION MERITS
// ============================================
model CharacterMerit {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  meritId     String
  merit       Merit     @relation(fields: [meritId], references: [id])
  
  // Purchase info
  pointCost   Int       // How many points this merit costs
  xpCost      Int?      // How much XP was spent to buy it
  purchasedAt DateTime  @default(now())
  
  // Notes
  notes       String?   @db.Text
  
  @@unique([characterId, meritId])
  @@index([characterId])
  @@index([meritId])
}

// ============================================
// POST-CREATION FLAWS
// ============================================
model CharacterFlaw {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  flawId      String
  flaw        Merit     @relation(fields: [flawId], references: [id])  // Changed from Flaw to Merit
  
  // Purchase info (buying off flaws costs XP)
  pointValue  Int       // How many points this flaw was worth
  xpCost      Int?      // How much XP to buy it off (if removed)
  removedAt   DateTime? // When it was bought off
  
  // Notes
  notes       String?   @db.Text
  acquiredAt  DateTime  @default(now())
  
  @@unique([characterId, flawId])
  @@index([characterId])
  @@index([flawId])
}

model Merit {
  id          String   @id @default(cuid())
  name        String
  category    String   // Physical, Mental, Social, Supernatural, Companion, Special Advantage, Genetic Flaw
  type        String   // "merit", "flaw", "background"
  subtype     String?  // For backgrounds: "general" or "mage"
  cost        String   // Point cost as text: "1", "1-5", "Variable", etc.
  description String   @db.Text
  pageRef     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  characterMerits CharacterMerit[]
  characterFlaws CharacterFlaw[]

  @@index([category])
  @@index([type])
  @@index([subtype])
}
model Wonder {
  id              String   @id @default(cuid())
  name            String
  category        String   // "Artifact/Invention", "Charm/Gadget", "Talisman/Device", "Fetish", "Grimoire/Principia", "Primer", "Periapt/Matrix"
  description     String   @db.Text
  
  // Wonder-specific traits
  backgroundCost  String?  // "1", "2-5", "Variable", etc.
  arete           Int?     // Arete requirement (or Gnosis for Fetishes)
  quintessence    Int?     // Quintessence cost
  
  // Optional fields
  spheres         Json?    // Required spheres (if any): { "Prime": 3, "Forces": 2 }
  pageRef         String?
  
  // Creator info
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  // Relations
  characters      CharacterWonder[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([userId])
  @@index([name])
}
model CharacterWonder {
  id          String    @id @default(cuid())
  characterId String
  wonderId    String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  wonder      Wonder    @relation(fields: [wonderId], references: [id], onDelete: Cascade)
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  
  @@unique([characterId, wonderId])
  @@index([characterId])
  @@index([wonderId])
}

// ============================================
// OFFICIAL XP COSTS (Mage: The Ascension)
// ============================================
model ExperienceCost {
  id          String  @id @default(cuid())
  
  // What is being improved
  category    String  @unique  // "attribute", "ability", "arete", "sphere", "willpower", etc.
  
  // Cost formula
  costType    String  // "multiplier" or "flat"
  multiplier  Int?    // For "new rating x N" costs
  flatCost    Int?    // For flat costs
  
  // Description
  name        String  // Display name
  formula     String  // Human-readable formula (e.g., "new rating × 4")
  description String  @db.Text
  
  // Book reference
  bookRef     String? // Page reference
  
  // System
  isOfficial  Boolean @default(true)
}

model MageGroup {
  id                  String   @id @default(cuid())
  name                String   @unique
  slug                String   @unique
  category            String
  description         String   @db.Text
  philosophy          String?  @db.Text
  practices           String?  @db.Text
  organization        String?  @db.Text
  symbolImage         String?
  logoImage           String?
  representativeImage String?
  published           Boolean  @default(false)
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([category])
  @@index([published])
  @@index([slug])
}

// ============================================
// POST-CREATION BACKGROUNDS
// ============================================
model CharacterBackground {
  id            String     @id @default(cuid())
  characterId   String
  character     Character  @relation(fields: [characterId], references: [id], onDelete: Cascade)
  backgroundId  String
  background    Background @relation(fields: [backgroundId], references: [id])
  
  // Rating info
  currentRating Int        @default(1)  // Current dots (1-5)
  startRating   Int        @default(0)  // What it was at character creation
  
  // XP tracking for each increase
  xpSpent       Int        @default(0)  // Total XP spent on this background
  purchaseLog   Json?      // Array of {from: 0, to: 1, xpCost: 3, date: "..."}
  
  // Metadata
  acquiredAt    DateTime   @default(now())
  notes         String?    @db.Text
  
  @@unique([characterId, backgroundId])
  @@index([characterId])
  @@index([backgroundId])
}

model Background {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String?  // For future categorization (Social, Resources, Power, etc.)
  subtype     String   // "general" or "mage"
  cost        String   // "Variable", "Double Cost", etc.
  description String   @db.Text
  pageRef     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  characterBackgrounds CharacterBackground[]

  @@index([subtype])
}

model Resource {
  id          String   @id @default(cuid())
  name        String
  type        String   // podcast, website, book, video, article, tool, etc.
  category    String?  // Optional: Lore, Rules, Storytelling, Character Building, etc.
  description String   @db.Text
  url         String?  // Link to resource
  author      String?  // Creator/author name
  imageUrl    String?  // Optional image/logo
  featured    Boolean  @default(false) // Admin can feature certain resources
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  imageLayout String? @default("top")

  @@index([type])
  @@index([featured])
}

model SiteSettings {
  id                String   @id @default(cuid())
  key               String   @unique
  value             String   @db.Text
  footerText        String   @default("") @db.Text
  welcomeTitle      String   @default("Welcome, Newly Awakened") @db.Text
  welcomeText       String   @default("") @db.Text
  aboutPage         String   @default("") @db.Text
  
  // NEW: Split About into two sections
  aboutOwnerTitle   String   @default("About the Owner") @db.Text
  aboutOwnerText    String   @default("") @db.Text
  aboutOwnerImage   String   @default("") @db.Text  // URL to owner image
  aboutSiteTitle    String   @default("About the Site") @db.Text
  aboutSiteText     String   @default("") @db.Text
  aboutSectionOrder String   @default("owner,site") // "owner,site" or "site,owner"
  
  howToUse          String   @default("") @db.Text
  creditsPage       String   @default("") @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model CharacterCreationContent {
  id         String   @id @default(cuid())
  key        String   @unique @default("main")
  overview   String   @default("") @db.Text
  attributes String   @default("") @db.Text
  abilities  String   @default("") @db.Text
  spheres    String   @default("") @db.Text
  finishing  String   @default("") @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
model GuideExpandedContent {
  id          String   @id @default(cuid())
  key         String   @unique @default("main")
  concept     String   @default("") @db.Text
  attributes  String   @default("") @db.Text
  abilities   String   @default("") @db.Text
  spheres     String   @default("") @db.Text
  backgrounds String   @default("") @db.Text
  freebies    String   @default("") @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// SITE UPDATES & ANNOUNCEMENTS
// ============================================
model SiteUpdate {
  id          String    @id @default(cuid())
  title       String    // e.g., "Added Experience Tracker"
  description String    @db.Text  // Markdown supported
  category    String    // "Feature", "Bug Fix", "Content", "Improvement", "Announcement"
  published   Boolean   @default(false)
  priority    Int       @default(0)  // Higher = shows first
  date        DateTime  @default(now())  // Update date
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([published])
  @@index([date])
  @@index([priority])
}

// ============================================
// UPCOMING BOOK RELEASES
// ============================================
model BookRelease {
  id              String    @id @default(cuid())
  title           String    // Book title
  publisher       String?   // "Onyx Path", "White Wolf", etc.
  description     String    @db.Text  // Markdown supported
  releaseDate     DateTime? // Expected or actual release date
  status          String    // "Announced", "Pre-order", "Released", "Delayed"
  coverImageUrl   String?   // Cover art URL
  purchaseUrl     String?   // Where to buy
  announcementUrl String?   // Official announcement link
  published       Boolean   @default(false)
  priority        Int       @default(0)  // Higher = shows first
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([published])
  @@index([status])
  @@index([releaseDate])
  @@index([priority])
}
