// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  name          String?
  passwordHash  String
  isAdmin       Boolean     @default(false)
  resetToken    String?     @unique
  resetTokenExpiry DateTime?
  characters    Character[]
  rotes         Rote[]      // User's created rotes
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Character {
  id           String          @id @default(cuid())
  name         String
  faction      String          // Tradition/affiliation from guided creation
  concept      String?         // Character concept/background
  
  // Basic Info from guided creation
  player       String?         // Player's name
  chronicle    String?         // Campaign name
  nature       String?         // Nature archetype
  demeanor     String?         // Demeanor archetype
  essence      String?         // Dynamic, Pattern, Primordial, Questing
  sect         String?         // Sect (optional)
  
  // Stats (stored as JSON for flexibility)
  attributes   Json?           // { strength: 2, dexterity: 3, ... }
  abilities    Json?           // { alertness: 2, brawl: 1, ... }
  spheres      Json?           // { correspondence: 2, forces: 1, ... }
  backgrounds  Json?           // { avatar: 3, library: 2, ... }
  specialties  Json?           // { brawl: "Dirty Fighting", ... }
  
  // Derived from guided creation
  arete        Int?            // Total arete (base 1 + freebie dots)
  willpower    Int?            // Total willpower (base 5 + freebie dots)
  
  // Freebie tracking (for editing later)
  freebieDots  Json?           // Store all freebie allocations
  merits       Json?           // Array of { id, name, cost }
  flaws        Json?           // Array of { id, name, cost }
  
  // Metadata
  avatar       String?         // Avatar description
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  rotes        CharacterRote[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([userId])
  @@index([faction])
}

model CharacterRote {
  id          String    @id @default(cuid())
  characterId String
  roteId      String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  rote        Rote      @relation(fields: [roteId], references: [id], onDelete: Cascade)
  notes       String?   @db.Text // Personal notes about how they use this rote
  specialty   Boolean   @default(false) // Is this a specialty rote?
  createdAt   DateTime  @default(now())
  
  @@unique([characterId, roteId]) // Can't assign same rote twice to one character
  @@index([characterId])
  @@index([roteId])
}

model Rote {
  id          String          @id @default(cuid())
  name        String
  tradition   String
  description String          @db.Text
  spheres     Json            // Store as JSON: { "Forces": 3, "Prime": 2 }
  level       String
  pageRef     String?
  userId      String?         // Optional - null for admin-created rotes
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  characters  CharacterRote[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([tradition])
  @@index([level])
  @@index([userId])
}

model Merit {
  id          String   @id @default(cuid())
  name        String
  category    String   // Physical, Mental, Social, Supernatural, Companion, Special Advantage, Genetic Flaw
  type        String   // "merit", "flaw", "background"
  subtype     String?  // For backgrounds: "general" or "mage"
  cost        String   // Point cost as text: "1", "1-5", "Variable", etc.
  description String   @db.Text
  pageRef     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([type])
  @@index([subtype])
}
model MageGroup {
  id                  String   @id @default(cuid())
  name                String   @unique
  slug                String   @unique
  category            String
  description         String   @db.Text
  philosophy          String?  @db.Text
  practices           String?  @db.Text
  organization        String?  @db.Text
  symbolImage         String?
  logoImage           String?
  representativeImage String?
  published           Boolean  @default(false)
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([category])
  @@index([published])
  @@index([slug])
}

model Background {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String?  // For future categorization (Social, Resources, Power, etc.)
  subtype     String   // "general" or "mage"
  cost        String   // "Variable", "Double Cost", etc.
  description String   @db.Text
  pageRef     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([subtype])
}

model Resource {
  id          String   @id @default(cuid())
  name        String
  type        String   // podcast, website, book, video, article, tool, etc.
  category    String?  // Optional: Lore, Rules, Storytelling, Character Building, etc.
  description String   @db.Text
  url         String?  // Link to resource
  author      String?  // Creator/author name
  imageUrl    String?  // Optional image/logo
  featured    Boolean  @default(false) // Admin can feature certain resources
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  imageLayout String? @default("top")

  @@index([type])
  @@index([featured])
}

model SiteSettings {
  id                String   @id @default(cuid())
  key               String   @unique
  value             String   @db.Text
  footerText        String   @default("") @db.Text
  welcomeTitle      String   @default("Welcome, Newly Awakened") @db.Text
  welcomeText       String   @default("") @db.Text
  aboutPage         String   @default("") @db.Text
  
  // NEW: Split About into two sections
  aboutOwnerTitle   String   @default("About the Owner") @db.Text
  aboutOwnerText    String   @default("") @db.Text
  aboutOwnerImage   String   @default("") @db.Text  // URL to owner image
  aboutSiteTitle    String   @default("About the Site") @db.Text
  aboutSiteText     String   @default("") @db.Text
  aboutSectionOrder String   @default("owner,site") // "owner,site" or "site,owner"
  
  howToUse          String   @default("") @db.Text
  creditsPage       String   @default("") @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model CharacterCreationContent {
  id         String   @id @default(cuid())
  key        String   @unique @default("main")
  overview   String   @default("") @db.Text
  attributes String   @default("") @db.Text
  abilities  String   @default("") @db.Text
  spheres    String   @default("") @db.Text
  finishing  String   @default("") @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
model GuideExpandedContent {
  id          String   @id @default(cuid())
  key         String   @unique @default("main")
  concept     String   @default("") @db.Text
  attributes  String   @default("") @db.Text
  abilities   String   @default("") @db.Text
  spheres     String   @default("") @db.Text
  backgrounds String   @default("") @db.Text
  freebies    String   @default("") @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

